# Copy this to config.env and fill in. All scripts source it automatically.

# --- ER-X SSH target ---
# Default is the post-renumber management IP. On a brand-new ER-X (factory reset),
# set ER_HOST=192.168.1.1 for the initial bootstrap run.
ER_HOST=192.168.10.1
ER_USER=ubnt
# Required. The ubnt user's password. Used for sudo through ssh.
# Pre-bootstrap on a factory-reset router the password is whatever you set
# in the GUI on first login.
ER_PASS=

# --- LAN layout ---
# Management LAN that will be on eth0. Must NOT be 192.168.1.0/24
# (the Starshield NATs to that on its LAN-side).
LAN_MGMT_GATEWAY=192.168.10.1
LAN_MGMT_CIDR=192.168.10.0/24

# Extra LANs on eth2/3/4. Defaults are .2/.3/.4 to match the management scheme.
LAN2_GATEWAY=192.168.2.1
LAN3_GATEWAY=192.168.3.1
LAN4_GATEWAY=192.168.4.1

# --- Cloudflare ---
# Scoped API token (NOT the Global API Key) with:
#   Account.Cloudflare Tunnel:Edit
#   Account.Zero Trust:Edit
CF_TOKEN=
CF_ACCT=
TUNNEL_NAME=er-x-home

# Networks to advertise as WARP private networks. Reachable from any
# WARP-enrolled client. Includes 192.168.1.0/24 so WARP clients can also
# reach the Starshield's own NAT'd subnet via the ER-X.
CF_LAN_CIDRS=(
  192.168.1.0/24
  192.168.2.0/24
  192.168.3.0/24
  192.168.4.0/24
  192.168.10.0/24
)

# Set to 1 to also run split-tunnel surgery (replace 192.168.0.0/16 in the
# default WARP exclude with a complement set that keeps your home wifi and
# homelab subnets direct while routing 192.168.{1,2,3,4,10}.0/24 through
# the tunnel). Account-wide change. Skip and configure manually if your
# other 192.168.x subnets need protection.
CF_APPLY_SPLIT_TUNNEL=0

# Pin the tunnel protocol to WireGuard and disable auto-fallback. MASQUE
# can fail the in-tunnel DNS check on double-NAT'd networks.
CF_PIN_WIREGUARD=1

# --- Cross-compile target (don't change unless you're not on an ER-X) ---
GOARCH=mipsle
GOOS=linux
